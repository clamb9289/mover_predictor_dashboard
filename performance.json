<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mover Predictor</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --surface2: #222535;
    --border: #2e3147;
    --text: #e8eaf0;
    --muted: #6b6f84;
    --accent: #5b7fff;
    --green: #34d399;
    --green-bg: rgba(52,211,153,0.1);
    --red: #f87171;
    --red-bg: rgba(248,113,113,0.1);
    --gold: #fbbf24;
    --gold-bg: rgba(251,191,36,0.08);
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  .header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .header-left h1 { font-size: 18px; font-weight: 600; letter-spacing: -0.3px; }
  .header-left p { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .header-right { display: flex; align-items: center; gap: 10px; }
  .status-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; padding: 5px 12px; border-radius: 20px; font-weight: 500; }
  .status-paper { background: var(--gold-bg); color: var(--gold); border: 1px solid rgba(251,191,36,0.25); }
  .status-live { background: var(--green-bg); color: var(--green); border: 1px solid rgba(52,211,153,0.25); }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; }
  .dot.pulse { animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.4} }
  .refresh-info { font-size: 11px; color: var(--muted); }

  .tabs { display: flex; gap: 2px; padding: 12px 24px 0; background: var(--surface); border-bottom: 1px solid var(--border); }
  .tab { padding: 10px 18px; font-size: 13px; font-weight: 500; color: var(--muted); cursor: pointer; border-bottom: 2px solid transparent; transition: color 0.15s; user-select: none; }
  .tab:hover { color: var(--text); }
  .tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .main { padding: 24px; max-width: 1050px; margin: 0 auto; }
  .panel { display: none; }
  .panel.active { display: block; }

  .card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 20px; margin-bottom: 16px; }
  .card-title { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); margin-bottom: 16px; }

  /* Pick cards */
  .picks-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 14px; }
  .pick-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 18px; }
  .pick-card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
  .pick-rank { font-size: 11px; color: var(--muted); font-weight: 600; letter-spacing: 0.5px; margin-bottom: 4px; }
  .pick-ticker { font-size: 28px; font-weight: 700; letter-spacing: -1px; }
  .pick-ticker a { color: var(--text); text-decoration: none; }
  .pick-ticker a:hover { color: var(--accent); }
  .pick-live-price { text-align: right; }
  .live-price-value { font-size: 20px; font-weight: 700; }
  .live-price-label { font-size: 10px; color: var(--muted); margin-top: 2px; }
  .pick-pnl-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin: 12px 0; }
  .pnl-item { text-align: center; flex: 1; }
  .pnl-label { font-size: 10px; color: var(--muted); margin-bottom: 3px; }
  .pnl-value { font-size: 15px; font-weight: 600; }
  .pnl-value.pos { color: var(--green); }
  .pnl-value.neg { color: var(--red); }
  .pnl-value.flat { color: var(--muted); }
  .score-bar-wrap { margin-bottom: 10px; }
  .score-bar-label { display: flex; justify-content: space-between; font-size: 11px; color: var(--muted); margin-bottom: 4px; }
  .score-bar { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
  .score-bar-fill { height: 100%; background: var(--accent); border-radius: 2px; }
  .pick-headline { font-size: 11px; color: var(--muted); line-height: 1.5; margin-top: 8px; }
  .win-floor-badge { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 10px; background: var(--green-bg); color: var(--green); border: 1px solid rgba(52,211,153,0.2); margin-top: 6px; margin-right: 6px; }
  .stop-badge { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 10px; background: var(--red-bg); color: var(--red); border: 1px solid rgba(248,113,113,0.2); margin-top: 6px; margin-right: 6px; }
  .exited-badge { display: inline-block; font-size: 10px; padding: 2px 8px; border-radius: 10px; background: var(--surface); color: var(--muted); border: 1px solid var(--border); margin-top: 6px; margin-right: 6px; }

  .explainer-toggle { font-size: 11px; color: var(--accent); cursor: pointer; margin-top: 10px; user-select: none; display: inline-block; }
  .explainer-toggle:hover { text-decoration: underline; }
  .explainer-box { display: none; font-size: 12px; color: var(--muted); line-height: 1.6; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
  .explainer-box.open { display: block; }
  .signal-mini-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 10px; }
  .signal-mini { background: var(--surface); border-radius: 6px; padding: 8px 10px; }
  .signal-mini-label { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.4px; }
  .signal-mini-value { font-size: 13px; font-weight: 600; margin-top: 2px; }

  /* Stats */
  .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-bottom: 16px; }
  .stat-box { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 14px; text-align: center; }
  .stat-label { font-size: 11px; color: var(--muted); margin-bottom: 4px; }
  .stat-value { font-size: 24px; font-weight: 700; }
  .stat-value.pos { color: var(--green); }
  .stat-value.neg { color: var(--red); }
  .stat-value.neutral { color: var(--text); }
  .stat-value.warn { color: var(--gold); }

  /* Yesterday */
  .yesterday-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; }
  .yest-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 16px; }
  .yest-top-row { display: flex; align-items: center; gap: 14px; margin-bottom: 10px; }
  .yest-move { font-size: 22px; font-weight: 700; min-width: 72px; text-align: center; }
  .yest-move.pos { color: var(--green); }
  .yest-move.neg { color: var(--red); }
  .yest-move.flat { color: var(--muted); }
  .yest-ticker { font-size: 16px; font-weight: 600; }
  .yest-rank { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .yest-detail-row { display: flex; gap: 16px; font-size: 12px; color: var(--muted); padding-top: 10px; border-top: 1px solid var(--border); margin-top: 4px; }
  .yest-detail-item strong { color: var(--text); display: block; font-size: 13px; }
  .yest-postmortem { font-size: 12px; color: var(--muted); line-height: 1.6; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border); }
  .gainers-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
  .gainer-pill { background: var(--green-bg); color: var(--green); border: 1px solid rgba(52,211,153,0.2); padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
  .gainer-label { font-size: 11px; color: var(--muted); margin-bottom: 8px; }

  /* History table */
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; padding: 10px 14px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px; color: var(--muted); border-bottom: 1px solid var(--border); white-space: nowrap; }
  td { padding: 12px 14px; border-bottom: 1px solid rgba(46,49,71,0.5); vertical-align: middle; white-space: nowrap; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,0.02); }
  .td-ticker { font-weight: 600; font-size: 14px; }
  .td-pos { color: var(--green); font-weight: 500; }
  .td-neg { color: var(--red); font-weight: 500; }
  .td-flat { color: var(--muted); }
  .mode-badge { font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 600; letter-spacing: 0.3px; }
  .mode-paper { background: var(--gold-bg); color: var(--gold); border: 1px solid rgba(251,191,36,0.2); }
  .mode-live { background: var(--green-bg); color: var(--green); border: 1px solid rgba(52,211,153,0.2); }

  /* Chart */
  .chart-controls { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; align-items: center; }
  .chart-toggle-group { display: flex; background: var(--surface2); border-radius: 8px; padding: 3px; gap: 2px; }
  .chart-toggle-btn { padding: 6px 14px; font-size: 12px; font-weight: 500; color: var(--muted); cursor: pointer; border-radius: 6px; user-select: none; transition: all 0.15s; }
  .chart-toggle-btn.active { background: var(--accent); color: white; }
  .chart-toggle-btn:hover:not(.active) { color: var(--text); }
  .chart-wrap { position: relative; height: 280px; margin-top: 8px; }
  .chart-legend { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 12px; font-size: 11px; color: var(--muted); }
  .chart-legend-item { display: flex; align-items: center; gap: 5px; }
  .chart-legend-dot { width: 8px; height: 8px; border-radius: 50%; }

  /* Model tab */
  .model-section { margin-bottom: 28px; }
  .model-section h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
  .model-section p { font-size: 13px; color: var(--muted); line-height: 1.7; }
  .signal-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; margin-top: 12px; }
  .signal-card { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }
  .signal-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .signal-weight { font-size: 20px; font-weight: 700; color: var(--accent); margin-bottom: 6px; }
  .signal-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
  .rule-list { margin-top: 12px; }
  .rule { display: flex; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
  .rule:last-child { border-bottom: none; }
  .rule-icon { font-size: 16px; flex-shrink: 0; }
  .rule-text { color: var(--muted); line-height: 1.5; }
  .rule-text strong { color: var(--text); }

  .loading-msg { text-align: center; padding: 60px 20px; color: var(--muted); font-size: 14px; }
  .error-msg { text-align: center; padding: 40px 20px; color: var(--red); font-size: 13px; line-height: 1.6; }
  .updated-at { font-size: 11px; color: var(--muted); margin-top: 10px; }
  .spinning { animation: spin 1s linear infinite; display: inline-block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Backtest run sub-tabs */
  .bt-run-tab {
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    user-select: none;
    transition: all 0.15s;
  }
  .bt-run-tab:hover { color: var(--text); border-color: var(--accent); }
  .bt-run-tab.active { color: var(--accent); border-color: var(--accent); background: rgba(91,127,255,0.08); }

  /* Colored pick percentages in backtest table */
  .pick-pos { color: var(--green); font-weight: 500; }
  .pick-neg { color: var(--red); font-weight: 500; }
  .pick-flat { color: var(--muted); }

  /* Backtest sub-tabs */
  .bt-run-tab {
    font-size: 11px;
    padding: 5px 12px;
    border-radius: 20px;
    cursor: pointer;
    border: 1px solid var(--border);
    color: var(--muted);
    background: var(--surface2);
    user-select: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .bt-run-tab:hover { color: var(--text); border-color: var(--accent); }
  .bt-run-tab.active { background: var(--accent); color: white; border-color: var(--accent); }
  .pick-pos { color: var(--green); font-weight: 500; }
  .pick-neg { color: var(--red); font-weight: 500; }
  .pick-flat { color: var(--muted); }
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <h1>📈 Mover Predictor</h1>
    <p id="header-sub">Loading...</p>
  </div>
  <div class="header-right">
    <span class="refresh-info" id="refresh-countdown"></span>
    <div id="status-badge" class="status-badge status-paper">
      <span class="dot pulse"></span> Paper Trading
    </div>
  </div>
</div>

<div class="tabs">
  <div class="tab active" onclick="showTab('today')">Today's Picks</div>
  <div class="tab" onclick="showTab('yesterday')">Yesterday</div>
  <div class="tab" onclick="showTab('history')">History</div>
  <div class="tab" onclick="showTab('backtest')">Backtest</div>
  <div class="tab" onclick="showTab('model')">The Model</div>
</div>

<div class="main">

  <div id="tab-today" class="panel active">
    <div class="stats-row">
      <div class="stat-box"><div class="stat-label">Hit Rate</div><div class="stat-value neutral" id="s-hitrate">—</div></div>
      <div class="stat-box"><div class="stat-label">Days Tracked</div><div class="stat-value neutral" id="s-days">—</div></div>
      <div class="stat-box"><div class="stat-label">Total Hits</div><div class="stat-value neutral" id="s-hits">—</div></div>
      <div class="stat-box"><div class="stat-label">Predictions Made</div><div class="stat-value neutral" id="s-preds">—</div></div>
    </div>
    <div class="card">
      <div class="card-title">Today's Top 3 Picks <span id="live-spinner" style="display:none" class="spinning">↻</span></div>
      <div id="today-picks" class="picks-grid"><div class="loading-msg">Loading picks...</div></div>
      <p class="updated-at" id="today-date"></p>
      <p class="updated-at" id="prices-updated"></p>
    </div>
  </div>

  <div id="tab-yesterday" class="panel">
    <div class="card">
      <div class="card-title">Actual Top Gainers Yesterday</div>
      <div class="gainer-label">S&P 500 biggest movers from the prior session:</div>
      <div id="actual-gainers" class="gainers-row"></div>
    </div>
    <div class="card">
      <div class="card-title">Our Predictions — How Did They Do?</div>
      <div id="yesterday-picks" class="yesterday-grid"><div class="loading-msg">Loading...</div></div>
    </div>
  </div>

  <div id="tab-history" class="panel">
    <div class="card">
      <div class="card-title">Performance Over Time</div>
      <div class="chart-controls">
        <div class="chart-toggle-group">
          <div class="chart-toggle-btn active" data-mode="combined" onclick="setChartMode('combined')">Combined</div>
          <div class="chart-toggle-btn" data-mode="individual" onclick="setChartMode('individual')">By Stock</div>
        </div>
        <div class="chart-toggle-group">
          <div class="chart-toggle-btn active" data-view="daily" onclick="setChartView('daily')">Daily %</div>
          <div class="chart-toggle-btn" data-view="cumulative" onclick="setChartView('cumulative')">Cumulative %</div>
        </div>
      </div>
      <div class="chart-wrap"><canvas id="perf-chart"></canvas></div>
      <div class="chart-legend" id="chart-legend"></div>
    </div>
    <div class="card">
      <div class="card-title">Full Trade History</div>
      <div class="table-wrap">
        <table id="history-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>#</th>
              <th>Ticker</th>
              <th>Entry</th>
              <th>Exit</th>
              <th>Exit Reason</th>
              <th>Move</th>
              <th>$ Change</th>
              <th>Rank</th>
              <th>Mode</th>
            </tr>
          </thead>
          <tbody id="history-body">
            <tr><td colspan="10" class="loading-msg">Loading history...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="tab-backtest" class="panel">
    <div class="card">
      <div class="card-title">Backtest Results</div>
      <div id="backtest-run-tabs" style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px"></div>
      <div id="backtest-content"><div class="loading-msg">Loading backtest results...</div></div>
    </div>
  </div>

  <div id="tab-model" class="panel">
    <div class="card">
      <div class="card-title">How the Model Works — v2</div>
      <div class="model-section">
        <h3>Overview</h3>
        <p>Each morning before market open, the predictor runs a series of checks before selecting any stocks. It first checks whether the overall market is healthy enough to trade. If the market passes, it scores ~500 S&P 500 stocks on four signals and selects the top 3 most likely to move during the upcoming session. Stocks with upcoming earnings are excluded entirely.</p>
      </div>
      <div class="model-section">
        <h3>Step 1 — Market Regime Check</h3>
        <p>Before any picks are made, the model checks whether SPY (S&P 500 ETF) is down more than 0.5% from its prior close. If it is, no trades are made that day. Fighting a down market is one of the fastest ways to lose money consistently — sitting out on bad days protects capital.</p>
      </div>
      <div class="model-section">
        <h3>Step 2 — Universe Filter</h3>
        <p>The full S&P 500 is narrowed down before scoring begins. Stocks must have an average daily volume of at least 1.5 million shares and a price between $15 and $600. This eliminates illiquid names that can spike randomly and are hard to exit cleanly.</p>
      </div>
      <div class="model-section">
        <h3>Step 3 — Earnings Exclusion</h3>
        <p>Any stock with an earnings announcement within the next 3 days is automatically excluded. Earnings are a coin flip — a stock is just as likely to drop 10% as gain 10% on an earnings surprise. For a strategy targeting consistent 1–5% daily gains, earnings events are pure unnecessary risk.</p>
      </div>
      <div class="model-section">
        <h3>Scoring Signals</h3>
        <div class="signal-grid">
          <div class="signal-card">
            <div class="signal-name">Accumulation Signal</div>
            <div class="signal-weight">50%</div>
            <div class="signal-desc">High volume WITHOUT a big price move. This is the signature of smart money quietly buying before a move. Score = volume ratio ÷ (1 + price move). A stock with 3x normal volume but a flat price scores very high.</div>
          </div>
          <div class="signal-card">
            <div class="signal-name">Sector Momentum</div>
            <div class="signal-weight">25%</div>
            <div class="signal-desc">How well is the stock's sector performing today? Stocks in the top-performing sectors get a bonus. The sector tide lifts individual stocks — picking against a weak sector is an uphill battle.</div>
          </div>
          <div class="signal-card">
            <div class="signal-name">News Sentiment</div>
            <div class="signal-weight">10%</div>
            <div class="signal-desc">Headlines from the last 48 hours only. Used primarily as a negative filter — stocks with bad headlines (downgrades, misses, recalls) are downranked. Analyst actions count 2x.</div>
          </div>
          <div class="signal-card">
            <div class="signal-name">Relative Strength</div>
            <div class="signal-weight">15%</div>
            <div class="signal-desc">The stock's 5-day return vs its sector's return. A stock outperforming its own sector shows individual demand beyond market tailwinds. Validated at 15% — dropping below this level hurt backtest results.</div>
          </div>
        </div>
      </div>
      <div class="model-section">
        <h3>Trade Execution Rules</h3>
        <div class="rule-list">
          <div class="rule"><div class="rule-icon">🕙</div><div class="rule-text"><strong>Buy at 10:00am ET</strong> — slightly after open to avoid the initial volatility spike.</div></div>
          <div class="rule"><div class="rule-icon">⏱</div><div class="rule-text"><strong>Monitor every 15 minutes</strong> from 10:00am to 3:45pm ET.</div></div>
          <div class="rule"><div class="rule-icon">🟢</div><div class="rule-text"><strong>Staircase trailing stop</strong> — the floor steps up as the stock climbs. Hit +3% → floor locks at +3%. Hit +5% → floor steps to +5%. Hit +7% → +7%. Hit +10% → +10%. Hit +15% → +15%. Beyond +15%, the floor trails dynamically 2% below the all-time intraday peak. If the stock falls back below the active floor at any 15-min check, it's sold to lock in that gain.</div></div>
          <div class="rule"><div class="rule-icon">🚀</div><div class="rule-text"><strong>No upside cap</strong> — stocks that keep running are held as long as they stay above their active floor level.</div></div>
          <div class="rule"><div class="rule-icon">🔴</div><div class="rule-text"><strong>Hard stop at -5%</strong> — position sold immediately to cap losses.</div></div>
          <div class="rule"><div class="rule-icon">🔔</div><div class="rule-text"><strong>End-of-day close at 3:55pm ET</strong> — all remaining positions sold before market close.</div></div>
          <div class="rule"><div class="rule-icon">🛡</div><div class="rule-text"><strong>Daily loss limit: 5%</strong> — bot pauses for the rest of the day if hit.</div></div>
          <div class="rule"><div class="rule-icon">⛔</div><div class="rule-text"><strong>Total drawdown shutoff: 15%</strong> — bot disables itself permanently until manually re-enabled.</div></div>
          <div class="rule"><div class="rule-icon">📅</div><div class="rule-text"><strong>No trades on bearish market days</strong> — if SPY is down more than 0.5% from prior close, no positions are opened that day.</div></div>
          <div class="rule"><div class="rule-icon">📊</div><div class="rule-text"><strong>Earnings blackout</strong> — stocks with earnings in the next 3 days are never picked regardless of their score.</div></div>
        </div>
      </div>
      <div class="model-section">
        <h3>What May Be Added Next</h3>
        <p>As data accumulates, potential future improvements include: pre-market gap analysis, options flow as a sentiment signal, tighter sector concentration limits (no more than 1 pick per sector), and dynamic weight adjustment based on which signals have been most predictive historically.</p>
      </div>
    </div>
  </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
const PERF_URL = "https://raw.githubusercontent.com/clamb9289/mover_predictor_dashboard/main/performance.json";
const REFRESH_INTERVAL = 60;

let perfData = null;
let liveCountdown = REFRESH_INTERVAL;
let countdownTimer = null;
let chartMode = 'combined';
let chartView = 'daily';
let chartInstance = null;

const STOCK_COLORS = ['#5b7fff', '#34d399', '#fbbf24', '#f87171', '#a78bfa', '#22d3ee', '#fb923c'];

function showTab(name) {
  document.querySelectorAll('.tab').forEach((t,i) => {
    const names = ['today','yesterday','history','model','backtest'];
    // find index by data or position
    const tabNames = ['today','yesterday','history','backtest','model'];
    t.classList.toggle('active', tabNames[i] === name);
  });
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  if (name === 'history' && perfData) renderChart();
  if (name === 'backtest') loadBacktestResults();
}

function fmt(n, decimals=2) {
  if (n == null) return '—';
  return (n >= 0 ? '+' : '') + n.toFixed(decimals) + '%';
}

function fmtPrice(n) {
  if (n == null) return '—';
  return '$' + n.toFixed(2);
}

function fmtDollar(n) {
  if (n == null) return '—';
  return (n >= 0 ? '+$' : '-$') + Math.abs(n).toFixed(2);
}

function moveClass(n) {
  if (n == null) return 'td-flat';
  return n > 0 ? 'td-pos' : n < 0 ? 'td-neg' : 'td-flat';
}

function pnlClass(n) {
  if (n == null) return 'flat';
  return n > 0 ? 'pos' : n < 0 ? 'neg' : 'flat';
}

function toggleExplainer(id) {
  const el = document.getElementById(id);
  el.classList.toggle('open');
}

async function loadPerfData() {
  document.getElementById('live-spinner').style.display = 'inline-block';
  try {
    const res = await fetch(PERF_URL + '?t=' + Date.now());
    if (!res.ok) throw new Error('HTTP ' + res.status);
    perfData = await res.json();
    render(perfData);
    document.getElementById('prices-updated').textContent =
      'Data loaded: ' + new Date().toLocaleTimeString();
  } catch(e) {
    document.getElementById('today-picks').innerHTML =
      `<div class="error-msg">Could not load performance.json from GitHub.<br><small>${e.message}</small></div>`;
    document.getElementById('header-sub').textContent = 'Error loading data';
  }
  document.getElementById('live-spinner').style.display = 'none';
}

function startCountdown() {
  liveCountdown = REFRESH_INTERVAL;
  if (countdownTimer) clearInterval(countdownTimer);
  countdownTimer = setInterval(async () => {
    liveCountdown--;
    document.getElementById('refresh-countdown').textContent =
      `Refreshes in ${liveCountdown}s`;
    if (liveCountdown <= 0) {
      liveCountdown = REFRESH_INTERVAL;
      await loadPerfData();
    }
  }, 1000);
}

function render(data) {
  const days = (data.days || []).slice().sort((a,b) => b.date.localeCompare(a.date));
  const latest = days[0];

  document.getElementById('header-sub').textContent =
    latest ? `Picks for: ${latest.date}` : 'No data yet';

  if (latest) {
    const hr = latest.hit_rate;
    const hrEl = document.getElementById('s-hitrate');
    hrEl.textContent = (hr * 100).toFixed(0) + '%';
    hrEl.className = 'stat-value ' + (hr > 0.33 ? 'pos' : hr > 0 ? 'warn' : 'neg');
    document.getElementById('s-days').textContent = latest.days_tracked;
    document.getElementById('s-hits').textContent = latest.total_hits;
    document.getElementById('s-preds').textContent = latest.total_predictions;
  }

  renderTodayPicks(latest);
  renderYesterday(latest);
  renderHistory(days);
  if (document.getElementById('tab-history').classList.contains('active')) {
    renderChart();
  }
}

function renderTodayPicks(day) {
  const el = document.getElementById('today-picks');
  const dateEl = document.getElementById('today-date');
  if (!day?.predictions?.length) {
    el.innerHTML = '<div class="loading-msg">No picks available yet for today.</div>';
    return;
  }

  dateEl.textContent = 'Picks generated for session: ' + day.date;

  const scores = day.predictions.map(p => p.score);
  const maxScore = Math.max(...scores);
  const rankLabels = ['#1 — Top Pick', '#2 — Strong Signal', '#3 — Watch'];

  el.innerHTML = day.predictions.map((p, i) => {
    const pct = maxScore > 0 ? (p.score / maxScore) * 100 : 50;
    const entryPrice = p.entry_price;
    const livePrice = p.live_price ?? null;
    const pnlPct = p.live_pct ?? null;
    const priceUpdated = p.price_updated ?? null;
    const explainerId = `explainer-${i}`;

    let badges = '';
    if (p.paper_exit_reason) {
      badges += `<div class="exited-badge">⚪ Exited — ${p.paper_exit_reason}</div>`;
    } else if (pnlPct != null) {
      if (pnlPct >= 3) badges += `<div class="win-floor-badge">🟢 Win floor active</div>`;
      else if (pnlPct <= -5) badges += `<div class="stop-badge">🔴 Stop triggered</div>`;
    }

    const signals = p.signals || {};
    const signalGrid = `
      <div class="signal-mini-grid">
        <div class="signal-mini"><div class="signal-mini-label">Accumulation</div><div class="signal-mini-value">${signals.accumulation ?? '—'}</div></div>
        <div class="signal-mini"><div class="signal-mini-label">Sector Momentum</div><div class="signal-mini-value">${signals.sector_momentum_pct != null ? fmt(signals.sector_momentum_pct) : '—'}</div></div>
        <div class="signal-mini"><div class="signal-mini-label">News Sentiment</div><div class="signal-mini-value">${signals.news_sentiment ?? '—'}</div></div>
        <div class="signal-mini"><div class="signal-mini-label">Rel. Strength</div><div class="signal-mini-value">${signals.relative_strength_pct != null ? fmt(signals.relative_strength_pct) : '—'}</div></div>
      </div>`;

    return `<div class="pick-card">
      <div class="pick-card-top">
        <div>
          <div class="pick-rank">${rankLabels[i] || '#' + p.rank}</div>
          <div class="pick-ticker"><a href="https://finance.yahoo.com/quote/${p.ticker}" target="_blank">${p.ticker} ↗</a></div>
          ${p.sector ? `<div style="font-size:11px;color:var(--muted);margin-top:2px">${p.sector}</div>` : ''}
        </div>
        <div class="pick-live-price">
          <div class="live-price-value" style="color:${livePrice ? 'var(--text)' : 'var(--muted)'}">
            ${livePrice ? fmtPrice(livePrice) : '—'}
          </div>
          <div class="live-price-label">LIVE PRICE</div>
        </div>
      </div>

      <div class="pick-pnl-row">
        <div class="pnl-item">
          <div class="pnl-label">Entry Price</div>
          <div class="pnl-value flat">${entryPrice ? fmtPrice(entryPrice) : '—'}</div>
        </div>
        <div class="pnl-item">
          <div class="pnl-label">Change</div>
          <div class="pnl-value ${pnlClass(pnlPct)}">${fmt(pnlPct)}</div>
        </div>
        <div class="pnl-item">
          <div class="pnl-label">Score</div>
          <div class="pnl-value flat">${p.score.toFixed(3)}</div>
        </div>
      </div>

      <div class="score-bar-wrap">
        <div class="score-bar-label"><span>Signal strength</span><span>${pct.toFixed(0)}%</span></div>
        <div class="score-bar"><div class="score-bar-fill" style="width:${pct}%"></div></div>
      </div>

      ${p.headline ? `<div class="pick-headline">📰 ${p.headline}</div>` : ''}
      ${priceUpdated ? `<div class="updated-at">Price as of ${priceUpdated} (updates every 15 min during market hours)</div>` : '<div class="updated-at" style="color:var(--muted)">Live price updates during market hours</div>'}
      ${badges}

      <div class="explainer-toggle" onclick="toggleExplainer('${explainerId}')">Why this pick? ▾</div>
      <div class="explainer-box" id="${explainerId}">
        ${p.explainer || 'No explainer available for this pick.'}
        ${signalGrid}
      </div>
    </div>`;
  }).join('');
}

function renderYesterday(latest) {
  const gainersEl = document.getElementById('actual-gainers');
  if (latest?.actual_top3?.length) {
    gainersEl.innerHTML = latest.actual_top3.map(g =>
      `<div class="gainer-pill">${g.ticker} +${g.pct.toFixed(2)}%</div>`
    ).join('');
  } else {
    gainersEl.innerHTML = '<span style="color:var(--muted);font-size:13px">No data</span>';
  }

  const el = document.getElementById('yesterday-picks');
  if (!latest?.prior_predictions_actual?.length) {
    el.innerHTML = '<div class="loading-msg">No prior prediction data available.</div>';
    return;
  }

  el.innerHTML = latest.prior_predictions_actual.map(p => {
    const m = p.move_pct;
    const cls = m == null ? 'flat' : m > 0 ? 'pos' : 'neg';
    const rankText = p.actual_rank && p.total_ranked
      ? `#${p.actual_rank} of ${p.total_ranked} tracked`
      : '—';
    return `<div class="yest-card">
      <div class="yest-top-row">
        <div class="yest-move ${cls}">${m == null ? '—' : fmt(m)}</div>
        <div class="yest-info">
          <div class="yest-ticker">${p.ticker}</div>
          <div class="yest-rank">Our Rank #${p.rank} pick</div>
        </div>
      </div>
      <div class="yest-detail-row">
        <div class="yest-detail-item">
          <span>$ Change</span>
          <strong style="color:${m > 0 ? 'var(--green)' : m < 0 ? 'var(--red)' : 'var(--muted)'}">${fmtDollar(p.dollar_change)}</strong>
        </div>
        <div class="yest-detail-item">
          <span>Position</span>
          <strong>${p.position_size ? '$' + p.position_size.toFixed(2) : '—'}</strong>
        </div>
        <div class="yest-detail-item">
          <span>Actual Rank</span>
          <strong>${rankText}</strong>
        </div>
      </div>
      ${p.postmortem ? `<div class="yest-postmortem">📋 ${p.postmortem}</div>` : ''}
    </div>`;
  }).join('');
}

function renderHistory(days) {
  const tbody = document.getElementById('history-body');
  if (!days.length) {
    tbody.innerHTML = '<tr><td colspan="10" class="loading-msg">No history yet.</td></tr>';
    return;
  }

  const rows = [];
  for (const day of days) {
    const preds = day.predictions || [];
    const actuals = day.prior_predictions_actual || [];
    const actualMap = {};
    actuals.forEach(a => actualMap[a.ticker] = a);
    if (!preds.length) continue;

    preds.forEach((p, i) => {
      const a = actualMap[p.ticker];
      const move = a?.move_pct ?? p.live_pct ?? null;
      const mc = moveClass(move);
      const isLive = day.live_trading === true;
      const exitPrice = p.paper_exit_price ?? null;
      const exitReason = p.paper_exit_reason ?? (a ? 'End of day' : '—');
      const dollarChange = a?.dollar_change ?? null;
      const rankText = a?.actual_rank && a?.total_ranked ? `#${a.actual_rank}/${a.total_ranked}` : '—';

      rows.push(`<tr>
        ${i === 0 ? `<td rowspan="${preds.length}" style="font-weight:500">${day.date}</td>` : ''}
        <td style="color:var(--muted)">#${p.rank}</td>
        <td class="td-ticker">${p.ticker}</td>
        <td style="color:var(--muted)">${p.entry_price ? fmtPrice(p.entry_price) : '—'}</td>
        <td style="color:var(--muted)">${exitPrice ? fmtPrice(exitPrice) : '—'}</td>
        <td style="color:var(--muted);font-size:11px">${exitReason}</td>
        <td class="${mc}">${fmt(move)}</td>
        <td class="${mc}">${fmtDollar(dollarChange)}</td>
        <td style="color:var(--muted);font-size:12px">${rankText}</td>
        ${i === 0 ? `<td rowspan="${preds.length}"><span class="mode-badge ${isLive ? 'mode-live' : 'mode-paper'}">${isLive ? 'LIVE' : 'PAPER'}</span></td>` : ''}
      </tr>`);
    });
  }

  tbody.innerHTML = rows.join('') || '<tr><td colspan="10" class="loading-msg">No records found.</td></tr>';
}

function setChartMode(mode) {
  chartMode = mode;
  document.querySelectorAll('[data-mode]').forEach(b => b.classList.toggle('active', b.dataset.mode === mode));
  renderChart();
}

function setChartView(view) {
  chartView = view;
  document.querySelectorAll('[data-view]').forEach(b => b.classList.toggle('active', b.dataset.view === view));
  renderChart();
}

function buildDailyMoveData(days) {
  // Build map: date -> ticker -> move_pct, using prior_predictions_actual
  // (which records the previous day's predictions' actual outcomes)
  const sorted = days.slice().sort((a,b) => a.date.localeCompare(b.date));
  const byDate = {};
  const tickersSeen = new Set();

  sorted.forEach(day => {
    (day.prior_predictions_actual || []).forEach(p => {
      if (p.move_pct == null) return;
      // attribute this move to the day the prediction was FOR, not the day it was scored
      // best approximation: previous entry's date
    });
  });

  // Simpler approach: walk predictions directly with their own date,
  // using live_pct as a same-day proxy when prior_predictions_actual unavailable
  sorted.forEach(day => {
    const dayMoves = {};
    (day.predictions || []).forEach(p => {
      const move = p.paper_exit_pct ?? p.live_pct ?? null;
      if (move != null) {
        dayMoves[p.ticker] = move;
        tickersSeen.add(p.ticker);
      }
    });
    if (Object.keys(dayMoves).length) {
      byDate[day.date] = dayMoves;
    }
  });

  return { byDate, tickers: Array.from(tickersSeen), dates: Object.keys(byDate).sort() };
}

function renderChart() {
  const canvas = document.getElementById('perf-chart');
  if (!canvas || !perfData) return;
  const days = perfData.days || [];
  const { byDate, tickers, dates } = buildDailyMoveData(days);

  if (!dates.length) {
    if (chartInstance) { chartInstance.destroy(); chartInstance = null; }
    document.getElementById('chart-legend').innerHTML = '<span style="color:var(--muted)">Not enough data yet for a chart.</span>';
    return;
  }

  let datasets = [];
  let legendHtml = '';

  if (chartMode === 'combined') {
    // Average the 3 picks' moves per day
    let cumulative = 0;
    const dataPoints = dates.map(d => {
      const moves = Object.values(byDate[d]);
      const avg = moves.reduce((a,b) => a+b, 0) / moves.length;
      if (chartView === 'cumulative') {
        cumulative += avg;
        return cumulative;
      }
      return avg;
    });
    datasets = [{
      label: 'Portfolio Avg',
      data: dataPoints,
      borderColor: '#5b7fff',
      backgroundColor: 'rgba(91,127,255,0.1)',
      fill: true,
      tension: 0.3,
      pointRadius: 4,
      pointBackgroundColor: '#5b7fff',
    }];
    legendHtml = `<div class="chart-legend-item"><div class="chart-legend-dot" style="background:#5b7fff"></div>Portfolio Average (3-pick mean)</div>`;
  } else {
    tickers.forEach((ticker, i) => {
      const color = STOCK_COLORS[i % STOCK_COLORS.length];
      let cumulative = 0;
      const dataPoints = dates.map(d => {
        const val = byDate[d][ticker];
        if (val == null) return null;
        if (chartView === 'cumulative') {
          cumulative += val;
          return cumulative;
        }
        return val;
      });
      datasets.push({
        label: ticker,
        data: dataPoints,
        borderColor: color,
        backgroundColor: color + '20',
        fill: false,
        tension: 0.3,
        pointRadius: 3,
        pointBackgroundColor: color,
        spanGaps: true,
      });
      legendHtml += `<div class="chart-legend-item"><div class="chart-legend-dot" style="background:${color}"></div>${ticker}</div>`;
    });
  }

  document.getElementById('chart-legend').innerHTML = legendHtml;

  if (chartInstance) chartInstance.destroy();

  const ctx = canvas.getContext('2d');
  chartInstance = new Chart(ctx, {
    type: 'line',
    data: { labels: dates, datasets },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (ctx) => `${ctx.dataset.label}: ${ctx.parsed.y >= 0 ? '+' : ''}${ctx.parsed.y.toFixed(2)}%`
          }
        }
      },
      scales: {
        y: {
          grid: { color: 'rgba(255,255,255,0.05)' },
          ticks: { color: '#6b6f84', callback: (v) => v + '%' },
          // Center on zero
          grace: '10%',
        },
        x: {
          grid: { display: false },
          ticks: { color: '#6b6f84' }
        }
      }
    }
  });
}

const BACKTEST_BASE_URL = "https://api.github.com/repos/clamb9289/mover_predictor_dashboard/contents/backtest_results";
let allBacktestFiles = [];
let backtestCache = {};

async function loadBacktestResults() {
  const el = document.getElementById('backtest-content');
  const tabsEl = document.getElementById('backtest-run-tabs');
  el.innerHTML = '<div class="loading-msg">Fetching backtest runs...</div>';
  tabsEl.innerHTML = '';

  try {
    const apiRes = await fetch(BACKTEST_BASE_URL + '?t=' + Date.now());
    if (!apiRes.ok) throw new Error('No backtest results found yet — run mode=backtest in GitHub Actions first.');
    const files = await apiRes.json();
    allBacktestFiles = files.filter(f => f.name.endsWith('.json')).sort((a,b) => b.name.localeCompare(a.name));
    if (!allBacktestFiles.length) throw new Error('No backtest JSON files found.');

    // Build sub-tabs
    allBacktestFiles.forEach((f, i) => {
      const label = f.name.replace('backtest_', '').replace('.json', '');
      const btn = document.createElement('div');
      btn.className = 'bt-run-tab' + (i === 0 ? ' active' : '');
      btn.textContent = label;
      btn.onclick = () => selectBacktestRun(f, btn);
      tabsEl.appendChild(btn);
    });

    // Load most recent
    await selectBacktestRun(allBacktestFiles[0], tabsEl.children[0]);

  } catch(e) {
    el.innerHTML = `<div class="error-msg">${e.message}</div>`;
  }
}

async function selectBacktestRun(file, btnEl) {
  // Update active tab
  document.querySelectorAll('.bt-run-tab').forEach(b => b.classList.remove('active'));
  if (btnEl) btnEl.classList.add('active');

  const el = document.getElementById('backtest-content');

  // Use cache if available
  if (backtestCache[file.name]) {
    renderBacktest(backtestCache[file.name]);
    return;
  }

  el.innerHTML = '<div class="loading-msg">Loading run...</div>';
  try {
    const res = await fetch(file.download_url + '?t=' + Date.now());
    const data = await res.json();
    backtestCache[file.name] = data;
    renderBacktest(data);
  } catch(e) {
    el.innerHTML = `<div class="error-msg">Failed to load ${file.name}: ${e.message}</div>`;
  }
}

function pickPctHtml(pct) {
  if (pct == null) return '<span class="pick-flat">—</span>';
  const cls = pct > 0 ? 'pick-pos' : pct < 0 ? 'pick-neg' : 'pick-flat';
  return `<span class="${cls}">${pct >= 0 ? '+' : ''}${pct.toFixed(1)}%</span>`;
}

function renderBacktest(data) {
  const el = document.getElementById('backtest-content');
  const s = data.summary;
  const p = data.params;
  const winRate = ((s.win_day_rate||0)*100).toFixed(0);
  const hitRate = ((s.hit_rate_3pct||0)*100).toFixed(0);

  el.innerHTML = `
    <div style="font-size:12px;color:var(--muted);margin-bottom:16px">
      Run: ${data.run_timestamp} &nbsp;|&nbsp; ${p.days} trading days &nbsp;|&nbsp;
      Sentiment: ${p.fixed_sentiment} &nbsp;|&nbsp;
      Preset: <strong style="color:var(--text)">${p.weights_preset || 'custom'}</strong> &nbsp;|&nbsp;
      Weights: Accum ${(p.weights.accumulation*100).toFixed(0)}% /
      Sector ${(p.weights.sector_momentum*100).toFixed(0)}% /
      News ${(p.weights.news_sentiment*100).toFixed(0)}% /
      RS ${(p.weights.relative_strength*100).toFixed(0)}%
    </div>

    <div class="stats-row" style="margin-bottom:20px">
      <div class="stat-box"><div class="stat-label">Total P&L</div>
        <div class="stat-value ${s.total_pnl>=0?'pos':'neg'}">${s.total_pnl>=0?'+':''}$${Math.abs(s.total_pnl).toFixed(2)}</div></div>
      <div class="stat-box"><div class="stat-label">Avg Daily P&L</div>
        <div class="stat-value ${s.avg_daily_pnl>=0?'pos':'neg'}">${s.avg_daily_pnl>=0?'+':''}$${Math.abs(s.avg_daily_pnl).toFixed(2)}</div></div>
      <div class="stat-box"><div class="stat-label">Win Day Rate</div>
        <div class="stat-value ${winRate>=50?'pos':'neg'}">${winRate}%</div></div>
      <div class="stat-box"><div class="stat-label">+3% Hit Rate</div>
        <div class="stat-value ${hitRate>=33?'pos':'warn'}">${hitRate}%</div></div>
      <div class="stat-box"><div class="stat-label">Avg Pick Return</div>
        <div class="stat-value ${s.avg_pick_pct>=0?'pos':'neg'}">${s.avg_pick_pct>=0?'+':''}${s.avg_pick_pct.toFixed(2)}%</div></div>
      <div class="stat-box"><div class="stat-label">Days Skipped</div>
        <div class="stat-value neutral">${s.skipped_days}</div></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px">
      <div class="stat-box" style="text-align:left;padding:16px">
        <div class="card-title">Best Day</div>
        <div style="font-size:18px;font-weight:700;color:var(--green)">${s.best_day?'+$'+s.best_day.day_total_pnl.toFixed(2):'—'}</div>
        <div style="font-size:12px;color:var(--muted);margin-top:4px">${s.best_day?s.best_day.trade_date+' — '+(s.best_day.picks||[]).map(pk=>pk.ticker).join(', '):''}</div>
      </div>
      <div class="stat-box" style="text-align:left;padding:16px">
        <div class="card-title">Worst Day</div>
        <div style="font-size:18px;font-weight:700;color:var(--red)">${s.worst_day?'$'+s.worst_day.day_total_pnl.toFixed(2):'—'}</div>
        <div style="font-size:12px;color:var(--muted);margin-top:4px">${s.worst_day?s.worst_day.trade_date+' — '+(s.worst_day.picks||[]).map(pk=>pk.ticker).join(', '):''}</div>
      </div>
    </div>

    <div style="margin-bottom:20px">
      <div class="card-title">Exit Reason Breakdown</div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:8px">
        ${Object.entries(s.exit_reasons||{}).map(([reason,count])=>
          `<div style="background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;font-size:12px">
            <div style="color:var(--muted)">${reason}</div>
            <div style="font-size:18px;font-weight:600;margin-top:2px">${count}</div>
          </div>`).join('')}
      </div>
      <div style="font-size:11px;color:var(--muted)">
        Accumulation signal correlation with returns:
        <strong style="color:var(--text)">${s.accumulation_return_correlation}</strong>
        (positive = higher accumulation score → better return)
      </div>
    </div>

    <div class="card-title">Daily Results</div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Trade Date</th><th>Picks</th><th>Avg %</th><th>Day P&L</th><th>W/L</th></tr></thead>
        <tbody>
          ${(data.daily_results||[]).slice().reverse().map(day => {
            const cls = day.day_total_pnl > 0 ? 'td-pos' : day.day_total_pnl < 0 ? 'td-neg' : 'td-flat';
            const wins = day.wins_3pct || 0;
            const total = (day.picks||[]).length;
            const wl = '🟢'.repeat(wins) + '🔴'.repeat(total - wins);
            const picksHtml = (day.picks||[]).map(pk =>
              `<strong>${pk.ticker}</strong>&nbsp;${pickPctHtml(pk.pct_change)}`
            ).join('&emsp;');
            return `<tr>
              <td style="white-space:nowrap">${day.trade_date}</td>
              <td style="font-size:12px">${picksHtml}</td>
              <td class="${cls}">${day.day_avg_pct >= 0 ? '+' : ''}${day.day_avg_pct.toFixed(1)}%</td>
              <td class="${cls}">${day.day_total_pnl >= 0 ? '+' : ''}$${Math.abs(day.day_total_pnl).toFixed(2)}</td>
              <td>${wl}</td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>
  `;
}

loadPerfData().then(() => startCountdown());
</script>
</body>
</html>
